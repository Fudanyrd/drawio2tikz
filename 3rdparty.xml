<?xml version="1.0" encoding="UTF-8"?>

<!--
 Third-party utilities

 Most of them are LaTex document utilities -
 formatting, building, and parsing.

 These should be installed via
 "mvn -f 3rdparty.xml install"
-->

<project>
  <modelVersion>4.0.0</modelVersion>
  <groupId>edu.fudan.jtex</groupId>
  <artifactId>latex-java</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <name>LaTex Toolkit</name>
  <packaging>pom</packaging>

  <properties>
    <maven.compiler.source>1.8</maven.compiler.source>
    <maven.compiler.target>1.8</maven.compiler.target>
  </properties>

  <modules>
    <module>texdoc</module>
    <module>texq</module>
  </modules>
</project>
